# Supabase (required for web + admin)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Video fitting appointments (Cal.com)
NEXT_PUBLIC_CALCOM_NAMESPACE=faden-j8bp3k
NEXT_PUBLIC_CALCOM_EVENT_SLUG=video-measurement
CALCOM_API_KEY=your-cal-com-api-key
CALCOM_WEBHOOK_SECRET=choose-a-random-webhook-secret
# Legacy fallbacks (optional if NEXT_PUBLIC_* vars are set)
CALCOM_DEFAULT_USERNAME=your-cal-username
CALCOM_DEFAULT_EVENT_SLUG=video-measurement

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...

# Cross-app cache revalidation (admin → web)
# Set the same value in both apps. A missing secret disables cache-busting.
WEB_APP_URL=https://your-web-app.vercel.app
REVALIDATE_SECRET=choose-a-random-revalidate-secret

# Email (Resend) — optional; skipped if not set
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@faden.in

# Error tracking (Sentry) — optional
# SENTRY_DSN=https://...@sentry.io/...

# Optional — Daily.co (not used; video links come from Cal.com Cal Video / Meet / Zoom)
# DAILY_API_KEY=
# DAILY_DOMAIN=your-subdomain.daily.co
